# Timber configuration — copy to `.env` and edit. NEVER commit your real `.env`.
#   cp .env.example .env
#
# Full env reference: USAGE.md. Only TIMBER_KEYS is needed to accept/serve logs;
# MONGODB_URI is needed for durability (flush to Mongo) and the query endpoints.

# --- Required ---

# API keys: JSON array of {key, app, env, mode}. mode = "write" (ingest) | "read".
# Generate long random keys. The read key is the one you hand to collaborators / an
# AI assistant. Empty/unset => every authed request is rejected (startup warning).
TIMBER_KEYS=[{"key":"w-dailyDashboard-prod-CHANGE_ME","app":"dailyDashboard","env":"prod","mode":"write"},{"key":"r-assistant-prod-CHANGE_ME","app":"assistant","env":"prod","mode":"read"}]

# Mongo/Atlas connection string. Unset => ingest still works (events durable in the
# WAL) but /v1/* queries answer 503 and the flusher idles until it is set.
MONGODB_URI=mongodb+srv://user:pass@cluster0.example.mongodb.net/?retryWrites=true&w=majority

# --- Optional (defaults shown) ---

# PORT=7710
# TIMBER_HOST=0.0.0.0          # bind address; 127.0.0.1 for a host-only run
# TIMBER_DB=appLogs
# TIMBER_COLLECTION=events
# TIMBER_WAL_DIR=/data/wal     # in the Docker image; ./wal-data when run bare
# TIMBER_WAL_BUDGET_MB=2048
# TIMBER_WAL_FSYNC_MS=50
# TIMBER_WAL_SEGMENT_MB=64
# TIMBER_WAL_RETAIN_HOURS=24
# TIMBER_TTL_DEBUG_DAYS=7
# TIMBER_TTL_INFO_DAYS=30
# TIMBER_TTL_WARN_DAYS=90
# TIMBER_TTL_ERROR_DAYS=90
# TIMBER_FLUSH_BATCH=1000
# TIMBER_FLUSH_INTERVAL_MS=200
# TIMBER_QUERY_MAX_TIME_MS=5000   # server-side read-query time cap; 0 disables
# TIMBER_CLUSTER=0                 # >0 forks N workers (one WAL subdir each)
